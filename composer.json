{
  "name": "webifycms/domain",
  "description": "The domain layer of the WebifyCMS",
  "type": "project",
  "authors": [
    {
      "name": "Mohammed Shifreen",
      "email": "mshifreen@gmail.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "symfony/uid": "^8.0"
  },
  "require-dev": {
    "webifycms/dev-tools": "^1.1",
    "phpunit/phpunit": "^13.1"
  },
  "autoload": {
    "psr-4": {
      "Webify\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Webify\\Test\\": "test/"
    }
  },
  "optimize-autoloader": true,
  "scripts": {
    "analyse": [
      "phpstan"
    ],
    "sniff": [
      "php-cs-fixer fix --show-progress=dots --diff --dry-run"
    ],
    "test": [
      "phpunit"
    ],
    "code-check": ["@analyse", "@sniff"],
    "code-format": [
      "php-cs-fixer fix --show-progress=dots"
    ]
  }
}
